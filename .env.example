# Server-only secrets — never prefix these with NEXT_PUBLIC_, never read them in client code.
GEMINI_API_KEY=
# Fallback LLM provider — used only when Gemini's request fails (quota/outage), see lib/claude.ts.
ANTHROPIC_API_KEY=
FINNHUB_API_KEY=

# Public Supabase config — safe to expose to the client by design.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — bypasses RLS, server-only. Used by the Stripe webhook and the watchlist cron.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (test mode only — no real charges).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=

# Shared secret the watchlist cron endpoint requires on every call (Vercel sends this
# automatically as `Authorization: Bearer <value>` once set as a project env var).
CRON_SECRET=
